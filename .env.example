# Perfil Spring: dev | prod | test
SPRING_PROFILES_ACTIVE=dev

# --- Desarrollo (JDBC directo) ---
DB_URL=jdbc:oracle:thin:@//localhost:1521/XEPDB1
DB_USERNAME=ALEDIESME
DB_PASSWORD=

# --- JWT (dev y prod, minimo 32 caracteres) ---
JWT_SECRET=
JWT_EXPIRATION_MS=3600000

# --- SQL runtime (oracle | common | h2) ---
# oracle: busca sql/oracle/ y hace fallback a sql/common/
SQL_DIALECT=oracle

# --- Produccion WebLogic ---
DB_JNDI_NAME=jdbc/AlediesmeDS
SERVER_PORT=8080
ALEDIESME_LOG_PATH=./logs
